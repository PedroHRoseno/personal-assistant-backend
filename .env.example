# Banco (Railway PostgreSQL recomendado em produção)
# Exemplo Railway:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=sqlite:///./personal_assistant.db

# Frontend(s) permitido(s) no CORS, separados por vírgula
# Exemplo:
# BACKEND_CORS_ORIGINS=https://seu-frontend.vercel.app,https://outro-dominio.com
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
